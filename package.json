{
    "name": "sqlnb-visualizer",
    "displayName": "SQL Notebook EDA",
    "description": "A lightweight Jupyter-style SQL notebook for PostgreSQL — built for data analysts",
    "icon": "images/icon.png",
    "version": "0.0.61",
    "publisher": "SQLNB",
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Notebooks",
        "Data Science"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/YaDilmurod/sqlnb"
    },
    "main": "./out/extension/extension.js",
    "contributes": {
        "notebookRenderer": [
            {
                "id": "sqlnb-table-renderer",
                "displayName": "SQL Notebook Table Renderer",
                "entrypoint": "./out/webview/renderer.mjs",
                "mimeTypes": [
                    "application/vnd.sqlnb.table"
                ],
                "requiresMessaging": "optional"
            },
            {
                "id": "sqlnb-chart-renderer",
                "displayName": "SQL Notebook Chart Renderer",
                "entrypoint": "./out/webview/chart-renderer.mjs",
                "mimeTypes": [
                    "application/vnd.sqlnb.chart"
                ],
                "requiresMessaging": "optional"
            },
            {
                "id": "sqlnb-summary-renderer",
                "displayName": "SQL Notebook Summary Renderer",
                "entrypoint": "./out/webview/summary-renderer.mjs",
                "mimeTypes": [
                    "application/vnd.sqlnb.summary"
                ],
                "requiresMessaging": "optional"
            },
            {
                "id": "sqlnb-schema-renderer",
                "displayName": "SQL Notebook Schema Renderer",
                "entrypoint": "./out/webview/schema-renderer.mjs",
                "mimeTypes": [
                    "application/vnd.sqlnb.schema"
                ],
                "requiresMessaging": "optional"
            },
            {
                "id": "sqlnb-connection-renderer",
                "displayName": "SQL Notebook Connection Renderer",
                "entrypoint": "./out/webview/connection-renderer.mjs",
                "mimeTypes": [
                    "application/vnd.sqlnb.connection"
                ],
                "requiresMessaging": "optional"
            }
        ],
        "languages": [
            {
                "id": "chart",
                "aliases": [
                    "Chart"
                ]
            },
            {
                "id": "summary",
                "aliases": [
                    "Summary"
                ]
            },
            {
                "id": "schema",
                "aliases": [
                    "Schema"
                ]
            },
            {
                "id": "connection",
                "aliases": [
                    "Connection"
                ]
            }
        ],
        "notebooks": [
            {
                "type": "sql-notebook",
                "displayName": "SQL Notebook",
                "selector": [
                    {
                        "filenamePattern": "*.sqlnb"
                    }
                ]
            }
        ],
        "commands": [
            {
                "command": "sqlNotebook.connect",
                "title": "SQL Notebook: Connect to Database"
            },
            {
                "command": "sqlNotebook.disconnect",
                "title": "SQL Notebook: Disconnect"
            },
            {
                "command": "sqlNotebook.showSchema",
                "title": "SQL Notebook: Show Schema (Tables & Columns)",
                "icon": "$(database)"
            },
            {
                "command": "sqlNotebook.exportCsv",
                "title": "SQL Notebook: Export Last Result to CSV"
            },
            {
                "command": "sqlNotebook.newNotebook",
                "title": "SQL Notebook: New Notebook"
            },
            {
                "command": "sqlNotebook.addChart",
                "title": "SQL Notebook: Add Chart Cell",
                "icon": "$(graph)"
            },
            {
                "command": "sqlNotebook.addSummary",
                "title": "SQL Notebook: Add Summary Cell",
                "icon": "$(list-flat)"
            },
            {
                "command": "sqlNotebook.sortData",
                "title": "SQL Notebook: Sort Table Server-Side"
            }
        ],
        "menus": {
            "notebook/toolbar": [
                {
                    "command": "sqlNotebook.addChart",
                    "group": "navigation",
                    "when": "notebookType == 'sql-notebook'"
                },
                {
                    "command": "sqlNotebook.addSummary",
                    "group": "navigation",
                    "when": "notebookType == 'sql-notebook'"
                },
                {
                    "command": "sqlNotebook.showSchema",
                    "group": "navigation",
                    "when": "notebookType == 'sql-notebook'"
                }
            ]
        },
        "configuration": {
            "title": "SQL Notebook",
            "properties": {
                "sqlNotebook.connectionString": {
                    "type": "string",
                    "default": "",
                    "description": "Currently active PostgreSQL connection string"
                },
                "sqlNotebook.connections": {
                    "type": "object",
                    "default": {},
                    "description": "Saved PostgreSQL connections (Key = Friendly Name, Value = Connection String)"
                },
                "sqlNotebook.maxRows": {
                    "type": "number",
                    "default": 500,
                    "description": "Maximum number of rows to display per query result"
                }
            }
        }
    },
    "scripts": {

        "vscode:prepublish": "npm run compile",
        "compile": "npm run compile:extension && npm run compile:webview",
        "watch": "tsc -watch -p ./",
        "package": "mkdir -p versions && npx @vscode/vsce package -o versions/",
        "compile:extension": "tsc -p ./",
        "compile:webview": "node build-webviews.js",
        "watch:extension": "tsc -watch -p ./",
        "watch:webview": "node build-webviews.js --watch"
    },
    "devDependencies": {
        "@types/node": "^18.x",
        "@types/pg": "^8.11.0",
        "@types/vscode": "^1.80.0",
        "esbuild": "^0.28.0",
        "typescript": "^5.3.0"
    },
    "dependencies": {
        "duckdb": "^1.4.4",
        "duckdb-async": "^1.4.2",
        "pg": "^8.11.3",
        "posthog-node": "^5.29.7"
    },
    "license": "MIT"
}
